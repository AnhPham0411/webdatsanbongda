generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum UserRole {
  ADMIN
  STAFF
  USER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// [MỚI CHO VOUCHER] Loại giảm giá
enum DiscountType {
  PERCENT // Giảm theo %
  FIXED // Giảm số tiền cố định (VND)
}

// --- MODELS ---

model Location {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?  @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courtTypes CourtType[]
}

model Sport {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  courtTypes CourtType[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings Booking[]
  reviews  Review[]
  accounts Account[]

  wishlists Wishlist[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model CourtType {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  basePrice   Decimal @db.Decimal(10, 2)
  capacity    Int

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  sportId String
  sport   Sport  @relation(fields: [sportId], references: [id], onDelete: Cascade)

  courts    Court[]
  amenities Amenity[]
}

model Court {
  id          String   @id @default(cuid())
  name        String
  courtTypeId String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  courtType      CourtType       @relation(fields: [courtTypeId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  images         CourtImage[]
  seasonalPrices SeasonalPrice[]

  wishlists Wishlist[]

  @@index([courtTypeId])
}

model CourtImage {
  id      String  @id @default(cuid())
  url     String
  altText String?
  courtId String
  court   Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId])
}

model Amenity {
  id         String      @id @default(cuid())
  name       String
  icon       String?
  courtTypes CourtType[]
}

// Model Voucher (Mã giảm giá)
model Voucher {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  startDate     DateTime
  endDate       DateTime
  usageLimit    Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

model TimeSlot {
  id        String   @id @default(cuid())
  startTime DateTime @db.Time
  endTime   DateTime @db.Time

  bookings Booking[]
}

model Booking {
  id         String   @id @default(cuid())
  userId     String
  courtId    String
  date       DateTime @db.Date
  timeSlotId String

  totalPrice    Decimal @db.Decimal(10, 2)
  depositAmount Decimal @default(0) @db.Decimal(10, 2)
  originalPrice Decimal @default(0) @db.Decimal(10, 2)

  voucherId     String?
  discountValue Decimal @default(0) @db.Decimal(10, 2)

  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  note          String?

  guestName  String?
  guestEmail String?
  guestPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  court    Court    @relation(fields: [courtId], references: [id])
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id])

  voucher Voucher? @relation(fields: [voucherId], references: [id])

  payment Payment?
  review  Review?

  @@index([courtId, date, timeSlotId])
  @@index([userId])
  @@index([voucherId])
}

model SeasonalPrice {
  id        String   @id @default(cuid())
  courtId   String
  startDate DateTime
  endDate   DateTime
  price     Decimal  @db.Decimal(10, 2)
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId])
}

model Review {
  id         String    @id @default(cuid())
  rating     Int
  comment    String?   @db.Text
  adminReply String?   @db.Text
  repliedAt  DateTime?
  userId     String
  bookingId  String    @unique
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  booking    Booking   @relation(fields: [bookingId], references: [id])

  @@index([userId])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  provider        String
  transactionCode String?
  paymentDate     DateTime      @default(now())
  status          PaymentStatus @default(UNPAID)
  booking         Booking       @relation(fields: [bookingId], references: [id])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  courtId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courtId])
  @@index([userId])
}

model Settings {
  id            String   @id @default("system")
  siteName      String   @default("Sport Arena")
  siteLogo      String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  openingTime   String   @default("06:00")
  closingTime   String   @default("23:00")
  minBookingDuration Int  @default(60) // phút
  maxAdvanceDays    Int   @default(30)
  cancelBeforeHours Int   @default(24)
  allowGuestBooking Boolean @default(true)
  maintenanceMode   Boolean @default(false)
  updatedAt         DateTime @updatedAt
}
